---
import { IconArrowLeft, IconArrowUpRight } from "@tabler/icons-react";
import Layout from "@/layouts/Layout.astro";
import Background from "@/components/Background.astro";
import Card from "@/components/Card.astro";
import { projects } from "@/data/projects";

const COLUMNS = 4;

function reorderForColumns<T>(items: T[], columns: number): T[] {
	const rows = Math.ceil(items.length / columns);
	const ordered: T[] = [];

	for (let col = 0; col < columns; col++) {
		for (let row = 0; row < rows; row++) {
			const index = row * columns + col;
			if (index < items.length) ordered.push(items[index]);
		}
	}

	return ordered;
}

const orderedProjects = reorderForColumns(projects, COLUMNS);
---

<Layout>
	<main class="w-screen min-h-screen text-neutral-300 relative">
		<Background />

		<div
			class="relative w-screen min-h-screen text-neutral-300 p-4 lg:p-6 xl:p-8 2xl:p-16 3xl:p-32 z-10">
			<div class="flex items-center gap-4 mb-6">
				<a
					class="hover:opacity-50 transition-opacity cursor-pointer"
					href="/"
					aria-label="Back to home">
					<IconArrowLeft stroke={2} size={28} />
				</a>

				<h1 class="text-3xl text-balance inter-600">Projects</h1>
			</div>

			<div
				class="columns-1 sm:columns-2 lg:columns-3 2xl:columns-4 gap-4 [column-fill:_balance]">
				{
					orderedProjects.map((project) => (
						<a
							class="group block mb-4 break-inside-avoid"
							href={project.href}
							target="_blank">
							<Card class="!p-0 h-full">
								{project.image && (
									<div class="relative aspect-video overflow-hidden bg-neutral-900">
										<img
											src={project.image}
											alt={`${project.name} preview`}
											loading="lazy"
											class="w-full h-full object-cover object-top select-none group-hover:scale-105 transition duration-300"
										/>

										<span class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors" />
									</div>
								)}

								<div class="flex flex-col gap-2 relative p-4 3xl:p-6">
									<span class="absolute top-4 right-4 3xl:top-6 3xl:right-6 opacity-50 group-hover:opacity-100 transition-opacity">
										<IconArrowUpRight
											stroke={2}
											size={22}
										/>
									</span>

									<h2 class="text-xl text-balance inter-600 text-purple-800 pr-7 group-hover:opacity-50 transition-opacity">
										{project.name}
									</h2>

									<div class="flex flex-wrap gap-1.5">
										{project.tags.map((tag) => (
											<span class="rounded-full bg-white/5 border border-white/10 px-2 py-0.5 text-xs text-neutral-300">
												{tag}
											</span>
										))}
									</div>

									<p class="text-neutral-400 text-pretty text-sm">
										{project.description}
									</p>
								</div>
							</Card>
						</a>
					))
				}
			</div>
		</div>
	</main>
</Layout>
