---
import Card from "@/components/Card.astro";

const experience = [
	{
		company: "Morning Value, Argentina",
		title: "Software Developer",
		period: "01/2026 - PRESENT",
		description:
			"Developed microservices using Go and Python with RabbitMQ as a message broker, integrated microfrontends built with JavaScript and React, and worked with large-scale databases.",
	},
	{
		company: "AuroraCore, Argentina",
		title: "Full-Stack Web Developer",
		period: "10/2023 - 01/2026",
		description:
			"Developed SaaS and legacy PHP applications where I learned about Project Design and Software Architecture, deployment with Docker, GitHub Actions, and databases like MySQL, PostgreSQL, SQL Server.",
	},
	{
		company: "Freelance",
		title: "Web Developer",
		description:
			"Built websites for clients, including the landing page for ``Fondo de Cine``, an independent film festival, using Astro.",
	},
];
---

<Card class="md:col-span-2 md:row-span-3 md:col-start-1 md:row-start-3">
	<div class="flex flex-col h-full gap-3">
		<h1 class="text-xl text-balance inter-600">Experience</h1>

		<div class="flex flex-col gap-4 overflow-y-auto pr-1 min-h-0 flex-1">
			{
				experience.map((item) => (
					<div class="flex flex-col gap-0.5">
						<span class="inter-600 text-pretty">
							{item.company}
						</span>
						<span class="text-purple-800 text-sm">
							{item.title}
						</span>
						{item.period && (
							<span class="text-neutral-500 text-xs">
								{item.period}
							</span>
						)}
						<span class="text-neutral-400 text-pretty text-sm mt-1">
							{item.description}
						</span>
					</div>
				))
			}
		</div>
	</div>
</Card>
