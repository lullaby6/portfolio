---
import { IconArrowUpRight } from "@tabler/icons-react";
import Card from "@/components/Card.astro";
---

<Card class="!p-0 md:col-span-3 md:row-span-3 md:col-start-3 md:row-start-1">
	<a
		class="group block w-full h-full relative cursor-pointer"
		href="/projects"
		aria-label="View all projects">
		{
			/*
			Previously a live <iframe src="/projects"> was used as the preview.
			It was replaced with a static screenshot for performance: the iframe
			loaded the entire /projects page (and all 15 project images) inside
			this card. A single image is far lighter. To revert, restore:

			<iframe
				src="/projects"
				title="Projects preview"
				tabindex="-1"
				class="absolute inset-0 w-full h-full border-0 pointer-events-none select-none overflow-hidden">
			</iframe>
		*/
		}
		<img
			src="/assets/images/projects/Projects2.png"
			alt="Projects preview"
			class="absolute inset-0 w-full h-full object-cover object-top select-none"
		/>

		<span
			class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors">
		</span>

		<span
			class="absolute bottom-0 left-0 w-full flex items-center justify-between gap-2 p-4 bg-gradient-to-t from-black/80 to-transparent">
			<span class="text-xl text-balance inter-600">Projects</span>
			<span
				class="flex items-center gap-1 text-sm text-neutral-300 group-hover:opacity-50 transition-opacity">
				View all
				<IconArrowUpRight stroke={2} size={18} />
			</span>
		</span>
	</a>
</Card>
