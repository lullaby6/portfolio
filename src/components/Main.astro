---
import {
	IconArrowUpRight,
	IconBrandGithub,
	IconBrandLinkedin,
	IconFileCv,
	IconMail,
} from "@tabler/icons-react";
---

<main class="w-screen min-h-screen text-neutral-300 relative">
	<span class="fixed top-0 left-0 w-screen h-screen bg-black">
		<span
			class="absolute top-0 left-0 h-64 w-64 m-6 md:m-32 rounded-full bg-gradient-to-r from-blue-500 via-purple-500 to-purple-800 opacity-25 animate-blob">
		</span>

		<span
			class="absolute bottom-0 left-0 h-64 w-64 rounded-full mx-128 my-32 bg-gradient-to-r from-blue-500 via-purple-500 to-purple-800 opacity-25 animate-blob hidden md:block">
		</span>

		<span
			class="absolute top-0 right-0 h-48 w-48 rounded-full mx-32 my-32 bg-gradient-to-r from-blue-500 via-purple-500 to-purple-800 opacity-25 animate-blob hidden md:block">
		</span>

		<span
			class="absolute bottom-0 right-0 h-64 w-64 rounded-full m-6 md:m-64 bg-gradient-to-r from-blue-500 via-purple-500 to-purple-800 opacity-25 animate-blob">
		</span>
	</span>

	<span class="fixed top-0 left-0 w-screen h-screen backdrop-blur-2xl"></span>

	<div
		class="absolute top-0 left-0 w-screen min-h-screen md:min-h-auto md:h-screen text-neutral-300 p-4 flex flex-col md:p-32 md:grid md:grid-cols-5 md:grid-rows-5 gap-4 z-10">
		<div
			class="relative overflow-hidden rounded-xl p-6 md:col-span-2 md:row-span-2">
			<span
				class="absolute top-0 left-0 w-full h-full bg-gradient-to-r from-blue-500 via-purple-500 to-purple-800 opacity-[0.05] pointer-events-none">
			</span>

			<div class="flex flex-col h-full">
				<div class="flex flex-col gap-2">
					<h1 class="text-2xl text-balance inter-600">
						Hi! 👋 I'm Luciano Brumer, alias lullaby6.
					</h1>

					<p class="text-neutral-400 text-pretty">
						I'm currently working at <a
							class="text-purple-800 hover:opacity-50"
							href="https://www.morningvalue.com/"
							target="_blank">
							Morning Value
						</a>as a Software Developer, using Golang, JavaScript,
						Python, React, and more. I started programming at 10
						years old using Python with Pygame, then I discovered
						web development and cybersecurity, and they became my
						passion.
					</p>
				</div>

				<div class="flex items-end gap-2 w-full justify-end h-full">
					<a
						class="hover:opacity-50 cursor-pointer"
						href="mailto:lucianobrumer5@gmail.com"
						target="_blank">
						<IconMail stroke={1} size={26} />
					</a>

					<a
						class="hover:opacity-50 cursor-pointer"
						href="https://github.com/lullaby6"
						target="_blank">
						<IconBrandGithub stroke={1} size={26} />
					</a>

					<a
						class="hover:opacity-50 cursor-pointer"
						href="https://www.linkedin.com/in/luciano-brumer/"
						target="_blank">
						<IconBrandLinkedin stroke={1} size={26} />
					</a>

					<a
						class="hover:opacity-50 cursor-pointer"
						href="https://www.linkedin.com/in/luciano-brumer/"
						target="_blank">
						<IconFileCv stroke={1} size={26} />
					</a>
				</div>
			</div>
		</div>

		<div
			class="relative overflow-hidden rounded-xl p-6 md:col-span-2 md:col-start-3">
			<span
				class="absolute top-0 left-0 w-full h-full bg-gradient-to-r from-blue-500 via-purple-500 to-purple-800 opacity-[0.05] pointer-events-none">
			</span>

			<div class="flex flex-col h-full">
				<div class="flex flex-col gap-2 relative">
					<a
						class="absolute top-0 right-0 w-full h-full flex jusitfy-end float-right text-right opacity-50 hover:opacity-100 transition-opacity"
						href="https://www.npmjs.com/~lullaby6"
						target="_blank">
						<span class="absolute top-0 right-0">
							<IconArrowUpRight stroke={2} size={26} />
						</span>
					</a>

					<h1 class="text-xl text-balance inter-600">NPM Packages</h1>

					<p class="text-neutral-400 text-pretty text-sm">
						I have published six packages on npm. The most
						interesting ones I can highlight are <a
							class="text-amber-600 hover:opacity-50"
							href="https://www.npmjs.com/package/locale-drive"
							target="_blank">
							Locale Drive
						</a>
						which provides a portal for transferring files within your
						local network, and <a
							class="text-blue-800 hover:opacity-50"
							href="https://www.npmjs.com/package/locale-drive"
							target="_blank">
							custom-html-element
						</a> which allows you to create reusable elements.
					</p>
				</div>
			</div>
		</div>

		<div
			class="relative overflow-hidden rounded-xl p-6 md:col-start-5 md:row-start-5">
			<span
				class="absolute top-0 left-0 w-full h-full bg-gradient-to-r from-blue-500 via-purple-500 to-purple-800 opacity-[0.05] pointer-events-none">
			</span>
			<!-- 3 -->
		</div>

		<div
			class="relative overflow-hidden rounded-xl p-6 md:col-span-2 md:col-start-3 md:row-start-2">
			<span
				class="absolute top-0 left-0 w-full h-full bg-gradient-to-r from-blue-500 via-purple-500 to-purple-800 opacity-[0.05] pointer-events-none">
			</span>

			<div class="flex flex-col h-full">
				<div class="flex flex-col gap-2 relative">
					<a
						class="absolute top-0 right-0 w-full h-full flex jusitfy-end float-right text-right opacity-50 hover:opacity-100 transition-opacity"
						href="https://packagist.org/packages/lullaby6/zschema"
						target="_blank">
						<span class="absolute top-0 right-0">
							<IconArrowUpRight stroke={2} size={26} />
						</span>
					</a>

					<h1 class="text-xl text-balance inter-600">
						Composer PHP Packages
					</h1>

					<p class="text-neutral-400 text-pretty text-sm">
						I've only released a single package for validating data
						types and schemas, inspired by Zod from TypeScript.
					</p>
				</div>
			</div>
		</div>

		<div
			class="relative overflow-hidden rounded-xl p-6 md:row-span-2 md:col-start-5 md:row-start-1">
			<span
				class="absolute top-0 left-0 w-full h-full bg-gradient-to-r from-blue-500 via-purple-500 to-purple-800 opacity-[0.05] pointer-events-none">
			</span>
			<!-- 5 -->
		</div>

		<div
			class="relative overflow-hidden rounded-xl p-6 row-span-3 col-start-1 md:row-start-3">
			<span
				class="absolute top-0 left-0 w-full h-full bg-gradient-to-r from-blue-500 via-purple-500 to-purple-800 opacity-[0.05] pointer-events-none">
			</span>
			<div class="flex flex-col h-full">
				<div class="flex flex-col gap-2">
					<h1 class="text-2xl text-balance inter-600">
						Game Development
					</h1>

					<p class="text-neutral-400 text-pretty">
						As another hobby, I also try to devote myself to
						developing 2D and 3D indie games using engines like
						Phaser, Godot, and Unity. Currently, I’ve only released
						a simple 2D bullet hell game, but I’m working on others.
					</p>
				</div>
			</div>
		</div>

		<div
			class="relative overflow-hidden rounded-xl p-6 md:col-span-2 row-span-3 col-start-2 md:row-start-3">
			<span
				class="absolute top-0 left-0 w-full h-full bg-gradient-to-r from-blue-500 via-purple-500 to-purple-800 opacity-[0.05] pointer-events-none">
			</span>

			<div class="flex flex-col h-full">
				<div class="flex flex-col gap-2">
					<h1 class="text-2xl text-balance inter-600">Projects</h1>

					<p class="text-neutral-400 text-pretty">
						Lorem ipsum dolor sit, amet consectetur adipisicing
						elit. Sequi officia corrupti fuga quis nisi
						necessitatibus ipsa, illo consequuntur repellat
						quibusdam aliquam quam nostrum. Sed vero aperiam
						possimus ipsum quas. Beatae.
					</p>
				</div>
			</div>
		</div>

		<div
			class="relative overflow-hidden rounded-xl p-6 md:col-span-2 md:row-span-2 col-start-4 md:row-start-3">
			<span
				class="absolute top-0 left-0 w-full h-full bg-gradient-to-r from-blue-500 via-purple-500 to-purple-800 opacity-[0.05] pointer-events-none">
			</span>
			<!-- 8 -->
		</div>

		<div
			class="relative overflow-hidden rounded-xl p-5 col-start-4 md:row-start-5">
			<span
				class="absolute top-0 left-0 w-full h-full bg-gradient-to-r from-blue-500 via-purple-500 to-purple-800 opacity-[0.05] pointer-events-none">
			</span>
			<div class="flex flex-col gap-2 relative">
				<a
					class="absolute top-0 right-0 w-full h-full flex jusitfy-end float-right text-right opacity-50 hover:opacity-100 transition-opacity"
					href="https://www.curseforge.com/members/lullaby6/projects?sortBy=TotalDownloads"
					target="_blank">
					<span class="absolute top-0 right-0">
						<IconArrowUpRight stroke={2} size={26} />
					</span>
				</a>

				<h1 class="text-xl text-balance inter-600">Minecraft Mods</h1>

				<p class="text-neutral-400 text-pretty text-sm">
					In my free time, I also create Minecraft mods; I've had over
					3 million downloads!
				</p>
			</div>
		</div>
	</div>
</main>
